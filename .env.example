# Shopee
SHOPEE_PARTNER_ID=2000000
SHOPEE_PARTNER_KEY=your_partner_key_hex_here
SHOPEE_SHOP_ID=123456789

# TikTok Shop
TIKTOKSHOP_APP_KEY=your_app_key
TIKTOKSHOP_APP_SECRET=your_app_secret
TIKTOKSHOP_SHOP_ID=7000000000000000000

# TikTok Shop small-pack reserve in physical pieces.
# The bot keeps up to this many pieces on the smallest pack variant,
# then pushes the remaining stock to the largest pack variant so large
# buyers are not blocked by one-order quantity limits.
# Example: 2000 pcs share + [1PCS, 100PCS] + reserve 200
#          => 200 x 1PCS and 18 x 100PCS.
TIKTOKSHOP_SMALL_PACK_RESERVE_PIECES=200

# Legacy fallback accepted by config.py during transition only.
# Prefer TIKTOKSHOP_SMALL_PACK_RESERVE_PIECES for new setup.
# TIKTOKSHOP_MAX_UNITS_PER_VARIANT=200

# Telegram (same chat as the order bots)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234
TELEGRAM_CHAT_ID=-1001234567890

# Safety ceiling (default 500). Increase only when Excel genuinely has more rows.
MAX_SKUS_PER_RUN=500
