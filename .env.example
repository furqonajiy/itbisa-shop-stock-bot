# Shopee
SHOPEE_PARTNER_ID=2000000
SHOPEE_PARTNER_KEY=your_partner_key_hex_here
SHOPEE_SHOP_ID=123456789
SHOPEE_API_BASE_URL=https://partner.shopeemobile.com
# For sandbox: https://partner.test-stable.shopeemobile.com

# TikTok Shop
TIKTOKSHOP_APP_KEY=your_app_key
TIKTOKSHOP_APP_SECRET=your_app_secret
TIKTOKSHOP_SHOP_ID=7000000000000000000
TIKTOKSHOP_AUTH_BASE_URL=https://auth.tiktok-shops.com
TIKTOKSHOP_OPEN_API_BASE_URL=https://open-api.tiktokglobalshop.com

# Telegram (same chat as the order bots)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234
TELEGRAM_CHAT_ID=-1001234567890

# Safety ceiling (default 500). Increase only when Excel genuinely has more rows.
MAX_SKUS_PER_RUN=500

# Local development knobs (optional). Default off.
USE_FAKE_SHOPEE=false
USE_FAKE_TIKTOKSHOP=false
